{
  "name": "freemap-v3-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FreemapSlovakia/freemap-v3-nodejs-backend.git"
  },
  "author": {
    "name": "Freemap Slovakia",
    "email": "freemap@freemap.sk"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/FreemapSlovakia/freemap-v3-nodejs-backend/issues"
  },
  "lint-staged": {
    "*.{js,ts}": ["biome check --error-on-warnings", "git add"]
  },
  "scripts": {
    "start": "node --enable-source-maps --import ./build/instrument.js build/index.js",
    "copy:proto": "cp src/routers/gallery/pictures.proto build/routers/gallery/pictures.proto",
    "build": "tsc && pnpm run copy:proto",
    "test": "tsc && node --test 'build/**/*.test.js'",
    "dev:serve": "pnpm run copy:proto && dotenvx run --overload -- sh -c 'node --enable-source-maps --import ./build/instrument.js build/index.js | pino-pretty -S -t -i hostname,pid'",
    "dev": "tsc-watch --onSuccess \"pnpm run dev:serve\"",
    "import:wikimedia": "dotenvx run --overload -- node --enable-source-maps build/wikimedia/importWikimedia.js",
    "deploy": "ssh ${DEPLOY_SSH_HOST:-freemap-fm6} 'cd /home/freemap/freemap-v3-nodejs-backend && git pull --ff-only && bash scripts/remote-deploy.sh'",
    "precommit": "lint-staged",
    "lint": "biome check --error-on-warnings",
    "lint:fix": "biome check --write --error-on-warnings"
  },
  "dependencies": {
    "@koa/router": "^15.7.0",
    "@mapbox/tilebelt": "^2.0.3",
    "@polar-sh/sdk": "^0.48.1",
    "@sentry/node": "^10.65.0",
    "@turf/bbox": "^7.3.5",
    "@turf/boolean-intersects": "^7.3.5",
    "@turf/center": "^7.3.5",
    "apple-signin-auth": "^2.0.0",
    "better-sqlite3": "^12.11.1",
    "etag": "^1.8.1",
    "exifreader": "^4.41.0",
    "gdal-async": "^3.12.3",
    "got": "^15.1.0",
    "heic-convert": "^2.1.0",
    "kcors": "^2.2.2",
    "koa": "^3.2.1",
    "koa-body": "^8.0.0",
    "koa-pino-logger": "^5.0.0",
    "koa-websocket": "^7.0.0",
    "mariadb": "^3.5.3",
    "nanoid": "^6.0.0",
    "oauth-1.0a": "^2.2.6",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "process-nextick-args": "^2.0.1",
    "protobufjs": "^8.7.1",
    "sharp": "0.35.3",
    "short-uuid": "^6.0.3",
    "source-map-support": "^0.5.21",
    "sql-template-tag": "^5.2.1",
    "tsc-watch": "^7.2.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3",
    "zod-openapi": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@dotenvx/dotenvx": "^2.7.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/etag": "^1.8.4",
    "@types/geojson": "^7946.0.16",
    "@types/heic-convert": "^2.1.1",
    "@types/kcors": "^2.2.9",
    "@types/koa": "^3.0.3",
    "@types/koa-websocket": "^5.0.11",
    "@types/node": "^24.13.3",
    "@types/ws": "^8.18.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "node-addon-api": "^8.9.0",
    "node-gyp": "^13.0.1",
    "pino-pretty": "^13.1.3",
    "typescript": "~7.0.2"
  },
  "resolutions": {
    "@types/koa": "^3.0.0"
  }
}
