{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2024",
    "moduleResolution": "NodeNext",
    "noImplicitAny": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "build",
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ES2024"],
    "strictNullChecks": true
  }
}
